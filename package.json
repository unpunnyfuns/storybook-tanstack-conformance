{
  "name": "storybook-tanstack-conformance",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "test": "npm run test --workspaces",
    "lint": "oxlint --deny-warnings",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "check": "oxfmt --check && oxlint --deny-warnings && npm run typecheck --workspaces",
    "test:router": "npm run test -w apps/router",
    "test:start": "npm run test -w apps/start",
    "storybook:router": "npm run storybook -w apps/router",
    "storybook:start": "npm run storybook -w apps/start",
    "e2e": "playwright test"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "oxfmt": "^0.58.0",
    "oxlint": "^1.71.0"
  }
}
